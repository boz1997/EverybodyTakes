rules_version = '2';

// Production security rules for GuestCam.
// Deploy with: firebase deploy --only firestore:rules
//
// Model: hosts own events; guests (anonymous or signed-in) join an event,
// write their own guest doc and photos, and may bump the event counters.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Users can only touch their own profile document.
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Content reports are write-only for users; only Cloud Functions (admin) read.
    match /reports/{reportId} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }

    // Client error logs are write-only (read them in the console/admin). Open to
    // create even unauthenticated so we still capture pre-auth failures; never
    // readable or mutable from the client.
    match /errorLogs/{logId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /events/{eventId} {
      function isHost() {
        return signedIn() && resource.data.hostId == request.auth.uid;
      }
      // Guests may only nudge the two counters by a single step — never write
      // an arbitrary value (which could zero out a cap or lock an event).
      function onlyCounters() {
        let d = request.resource.data;
        let r = resource.data;
        return signedIn()
          && d.diff(r).affectedKeys().hasOnly(['guestCount', 'photoCount'])
          && (d.guestCount == r.guestCount || d.guestCount == r.guestCount + 1)
          && (d.photoCount == r.photoCount || d.photoCount == r.photoCount + 1 || d.photoCount == r.photoCount - 1);
      }

      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isHost() || onlyCounters();
      allow delete: if isHost();

      // A guest owns their own guest doc; only the host can read the roster.
      match /guests/{guestId} {
        allow read: if signedIn()
          && (request.auth.uid == guestId
              || get(/databases/$(database)/documents/events/$(eventId)).data.hostId == request.auth.uid);
        allow create, update: if signedIn() && request.auth.uid == guestId;
        allow delete: if false;
      }

      // Photos are visible to participants only: the host, or a guest who has
      // actually joined (has a guest doc). Knowing an event id is not enough.
      match /photos/{photoId} {
        function isEventHost() {
          return get(/databases/$(database)/documents/events/$(eventId)).data.hostId == request.auth.uid;
        }
        function isParticipant() {
          return exists(/databases/$(database)/documents/events/$(eventId)/guests/$(request.auth.uid));
        }
        function isOwnerOrHost() {
          return signedIn() && (resource.data.uploadedBy == request.auth.uid || isEventHost());
        }
        function reportOnly() {
          return signedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['flagged', 'reportCount']);
        }
        // Any signed-in guest may like — touching only the like fields.
        function likeOnly() {
          return signedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['likedBy', 'likesCount']);
        }
        allow read: if signedIn() && (isParticipant() || isEventHost());
        allow create: if signedIn()
          && request.resource.data.uploadedBy == request.auth.uid
          && (isParticipant() || isEventHost());
        allow update: if isOwnerOrHost() || ((reportOnly() || likeOnly()) && isParticipant());
        allow delete: if isOwnerOrHost();
      }
    }
  }
}
