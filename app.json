{
  "expo": {
    "name": "GuestCam",
    "slug": "guestcam",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "guestcam",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#EFE7D6"
    },
    "ios": {
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:guestcam.store"
      ],
      "bundleIdentifier": "com.guestcam.app",
      "infoPlist": {
        "NSCameraUsageDescription": "GuestCam uses the camera so you can take photos and record videos inside an event you've joined.",
        "NSMicrophoneUsageDescription": "GuestCam uses the microphone when you record a video or leave a voice memory, so your clip has sound.",
        "NSPhotoLibraryUsageDescription": "GuestCam accesses your photos only when you choose to add an existing photo to an event.",
        "NSPhotoLibraryAddUsageDescription": "GuestCam saves photos and QR codes to your library only when you tap save.",
        "NSSupportsLiveActivities": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#EFE7D6"
      },
      "package": "com.guestcam.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-camera",
        {
          "cameraPermission": "GuestCam needs camera access to capture event moments.",
          "microphonePermission": "GuestCam needs microphone access to record event videos.",
          "recordAudioAndroid": true
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-live-activity",
      "expo-sharing",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.759909661412-56v7albtji1f8pmsi9ofejthes43rt18"
        }
      ],
      "./plugins/withGoogleModularHeaders.js",
      "expo-image",
      [
        "@sentry/react-native",
        {
          "organization": "guestcam",
          "project": "guestcam-mobile",
          "url": "https://de.sentry.io/"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "GuestCam uses the microphone when you record a video or leave a voice memory, so your clip has sound."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "googleIosClientId": "759909661412-56v7albtji1f8pmsi9ofejthes43rt18.apps.googleusercontent.com",
      "revenueCatIosKey": "appl_wexvGCqkWXzUjDvyCfNQlhPxWtn",
      "eas": {
        "projectId": "b3d702ff-7787-4a6b-8b0b-ffb5a1989da7"
      }
    }
  }
}
