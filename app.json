{
  "expo": {
    "name": "GuestCam",
    "slug": "guestcam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "guestcam",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.guestcam.app",
      "infoPlist": {
        "NSCameraUsageDescription": "GuestCam needs camera access to capture event moments.",
        "NSPhotoLibraryUsageDescription": "GuestCam needs photo library access.",
        "NSPhotoLibraryAddUsageDescription": "GuestCam needs permission to save photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.guestcam.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-camera",
        {
          "cameraPermission": "GuestCam needs camera access to capture event moments."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
