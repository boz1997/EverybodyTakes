rules_version = '2';

// Storage holds event photos/videos and cover images under events/{eventId}/.
// Any signed-in user (anonymous guests included) may read and upload to an
// event they've joined; downloads also work via tokenized getDownloadURL.
// Size caps are per media type so an "image" can't smuggle in 200 MB.
// Deploy with: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    match /events/{eventId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && ((request.resource.contentType.matches('image/.*')
              && request.resource.size < 15 * 1024 * 1024)     // 15 MB images
            || (request.resource.contentType.matches('video/.*')
              && request.resource.size < 200 * 1024 * 1024));  // 200 MB videos
    }
  }
}
