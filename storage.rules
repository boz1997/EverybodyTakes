rules_version = '2';

// Production Storage rules for GuestCam.
// Deploy with: firebase deploy --only storage
//
// Media lives under events/{eventId}/. Writing a photo/thumbnail requires being
// a *participant* of that event (the host, or a guest who has actually joined) —
// knowing an event id is no longer enough. Reads stay open to any signed-in user
// (downloads also work via tokenized getDownloadURL). Size caps are per media
// type so an "image" can't smuggle in 200 MB.
service firebase.storage {
  match /b/{bucket}/o {

    // The host of the event, or a guest who has joined (has a guest doc).
    function isParticipant(eventId) {
      return request.auth != null
        && (firestore.get(/databases/(default)/documents/events/$(eventId)).data.hostId == request.auth.uid
            || firestore.exists(/databases/(default)/documents/events/$(eventId)/guests/$(request.auth.uid)));
    }

    function isEventHost(eventId) {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/events/$(eventId)).data.hostId == request.auth.uid;
    }

    function validMedia() {
      return (request.resource.contentType.matches('image/.*')
                && request.resource.size < 15 * 1024 * 1024)      // 15 MB images
          || (request.resource.contentType.matches('video/.*')
                && request.resource.size < 200 * 1024 * 1024);    // 200 MB videos
    }

    function validAudio() {
      return request.resource.contentType.matches('audio/.*')
        && request.resource.size < 15 * 1024 * 1024;              // 15 MB — a 60 s m4a is ~1 MB
    }

    // Photos & their grid thumbnails: participants only.
    match /events/{eventId}/photos/{file=**} {
      allow read: if request.auth != null;
      allow write: if isParticipant(eventId) && validMedia();
    }
    match /events/{eventId}/thumbs/{file=**} {
      allow read: if request.auth != null;
      allow write: if isParticipant(eventId) && validMedia();
    }

    // Voice memories: one clip per guest, named after their uid ({uid}.m4a). A
    // participant may only write their own file; the author or the host may
    // delete it (host cleanup mirrors deleting the voice doc).
    match /events/{eventId}/voices/{fileName} {
      allow read: if request.auth != null;
      allow write: if isParticipant(eventId) && validAudio()
                   && fileName == request.auth.uid + '.m4a';
      allow delete: if fileName == request.auth.uid + '.m4a' || isEventHost(eventId);
    }

    // Cover image is uploaded by the host DURING event creation — before the
    // event document exists — so participation can't be checked yet. Any signed-in
    // user may write a single cover; type/size are still bounded.
    match /events/{eventId}/cover.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null && validMedia();
    }

    // The ZIP export is written only by the admin Cloud Function (which bypasses
    // these rules). Clients read their tokenized URL but never write it.
    match /events/{eventId}/export/{file=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
