{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@features/*": ["./features/*"],
      "@shared/*": ["./shared/*"],
      "@lib/*": ["./lib/*"],
      "@store/*": ["./store/*"],
      "@constants/*": ["./constants/*"],
      "@translations/*": ["./translations/*"]
    }
  }
}
